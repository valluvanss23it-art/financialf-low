PORT=5001
NODE_ENV=development
# Options: development, staging, production

# MongoDB Local Development
MONGODB_URI=mongodb://localhost:27017/financial_compass

# MongoDB Atlas (Cloud - Production Recommended)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/financial_compass?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d
# Generate secure key: openssl rand -base64 32

# ===== NEWS Feature Configuration =====
# NewsAPI.org - Free API for financial news
# Get your free API key from: https://newsapi.org/register
NEWS_API_KEY=your_news_api_key_here_get_from_newsapi_org

# How often to automatically fetch news updates (in minutes)
NEWS_UPDATE_INTERVAL=60

# News fetch categories (comma-separated)
# Options: general, india, global, tech, banking, crypto
NEWS_CATEGORIES=general,india,tech,banking

# Maximum number of news articles to store
NEWS_MAX_ARTICLES=1000

# News article retention period (in days)
# Articles older than this will be auto-deleted
NEWS_RETENTION_DAYS=30
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Optional: Redis Caching
# REDIS_URL=redis://localhost:6379

LOG_LEVEL=info
CORS_ORIGIN=http://localhost:8082,http://localhost:5173
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=10

# Feature Flags
ENABLE_USER_REGISTRATION=true
ENABLE_NEWS_FEED=true
ENABLE_ANALYTICS=false