# ==================== FRONTEND ENVIRONMENT VARIABLES ====================
# Copy this file to .env.local and update values for your environment

# ==================== API CONFIGURATION ====================
VITE_API_URL=http://127.0.0.1:5001/api
# In production: https://api.yourdomain.com

# ==================== APPLICATION MODE ====================
VITE_ENV=development
# Options: development, staging, production

# ==================== FEATURE FLAGS ====================
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_BETA_FEATURES=false
VITE_ENABLE_OFFLINE_MODE=false
VITE_ENABLE_NEWS_FEATURE=true
# Enable/disable the Daily Financial News feature

# ==================== NEWS FEATURE CONFIGURATION ====================
VITE_NEWS_PAGE_SIZE=20
# Number of articles to load per page

VITE_NEWS_REFRESH_INTERVAL=3600000
# Interval to automatically refresh news (in milliseconds, default: 1 hour)

VITE_NEWS_CATEGORIES=general,india,global,tech,banking,crypto
# Available news categories (comma-separated)

VITE_NEWS_DEFAULT_CATEGORY=general
# Default category to display when loading News page

# ==================== EXTERNAL SERVICES ====================
# Optional: Google Analytics
VITE_GA_ID=

# Optional: Sentry Error Tracking
VITE_SENTRY_DSN=

# Optional: Discord/Slack Notifications
VITE_WEBHOOK_URL=

# ==================== SECURITY ====================
VITE_MAX_SESSION_TIMEOUT=3600000
# Session timeout in milliseconds (1 hour default)

# ==================== UI CUSTOMIZATION ====================
VITE_CURRENCY_SYMBOL=₹
VITE_CURRENCY_CODE=INR
VITE_DATE_FORMAT=dd/MM/yyyy

# ==================== API CONFIGURATION ====================
VITE_API_TIMEOUT=30000
# Request timeout in milliseconds (30 seconds default)

VITE_API_RETRY_ATTEMPTS=3
# Number of retry attempts for failed requests